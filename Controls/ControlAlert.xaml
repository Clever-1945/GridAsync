<UserControl 
    x:Class="AsyncUI.Controls.ControlAlert"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:AsyncUI.Controls"
    mc:Ignorable="d"
    VerticalAlignment="Top"
    d:DesignHeight="450"
    d:DesignWidth="800">
    <Grid>
        <Border 
            BorderBrush="{Binding BorderBorderBrush}" 
            BorderThickness="2" 
            CornerRadius="20" 
            Background="{Binding BorderBackground}" 
            Padding="10" 
            >
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="35"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="30"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Grid.Column="0"
                    Text="{Binding TextIcon}" 
                    Foreground="{Binding BorderBorderBrush}" 
                    FontSize="18" 
                    Margin="0,0,10,0" 
                />

                <TextBox
                    Grid.Row="0"
                    Grid.Column="1"
                    Text="{Binding Message}"
                    IsReadOnly="True"
                    Background="Transparent" 
                    BorderThickness="0" 
                    BorderBrush="Transparent"
                    TextWrapping="NoWrap" 
                    AcceptsReturn="False" 
                    HorizontalScrollBarVisibility="Auto" 
                    VerticalScrollBarVisibility="Disabled"
                    FontSize="18"/>

                <TextBox
                    Grid.Row="1"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    IsReadOnly="True"
                    SpellCheck.IsEnabled="True"
                    Background="Transparent" 
                    BorderThickness="0" 
                    BorderBrush="Transparent"
                    TextWrapping="NoWrap" 
                    AcceptsReturn="False" 
                    HorizontalScrollBarVisibility="Disabled" 
                    VerticalScrollBarVisibility="Disabled"
                    Text="{Binding Description}" />

                <Button
                    Grid.Row="0"
                    Grid.Column="2"
                    Background="Transparent" 
                    BorderBrush="Transparent" 
                    BorderThickness="0"
                    FontSize="18"
                    Click="OnClickClose"
                    >X</Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
